{
  "name": "bullmq-ai-agent",
  "version": "0.5.2",
  "description": "AI agent library using BullMQ Flows for parallel multi-agent orchestration with LangChain",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "examples"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "cpx \"src/**/*.lua\" dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preexample": "npm run build && npm install .",
    "example": "tsx examples/cli.ts"
  },
  "keywords": [
    "bullmq",
    "ai-agent",
    "langchain",
    "llm",
    "multi-agent",
    "orchestrator",
    "openai",
    "redis",
    "queue",
    "workflow"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/humbertogontijo/bullmq-ai-agent.git"
  },
  "author": "humbertogontijo",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@langchain/cohere": "^1.0.4",
    "@langchain/community": "^1.1.22",
    "@langchain/core": "^1.1.25",
    "@langchain/openai": "^1.2.8",
    "@langchain/redis": "^1.1.0",
    "@langchain/textsplitters": "^1.0.1",
    "bullmq": "^5.70.4",
    "deepagents": "^1.8.1",
    "ioredis": "5.9.3",
    "langchain": "1.2.26"
  },
  "devDependencies": {
    "@clack/prompts": "^1.1.0",
    "cpx": "^1.5.0",
    "@types/node": "^25.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
